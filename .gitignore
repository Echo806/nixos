# Local secrets and runtime state
.env
.env.*
*.pem
*.key
*.age
secrets/

# Local agent settings that may contain paths/tokens
.claude/settings.local.json
.opencode/settings.local.json

# Hermes runtime state should not be committed
hermes/runtime/
hermes/**/.env
hermes/**/auth.json
hermes/**/state.db*
hermes/**/sessions/
hermes/**/logs/
hermes/**/cache/
hermes/**/sandboxes/
hermes/**/gateway*.json
hermes/**/gateway*.pid
hermes/**/gateway*.lock
